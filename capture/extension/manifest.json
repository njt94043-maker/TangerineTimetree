{
  "manifest_version": 3,
  "name": "TGT Audio Capture",
  "version": "2.0.0",
  "description": "WASAPI audio capture with side panel UI for practice library",
  "permissions": [
    "activeTab",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:9123/*",
    "http://localhost:5174/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
