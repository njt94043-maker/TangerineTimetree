{
  "name": "tgt-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "TGT monorepo: GigBooks (native) + Tangerine Timetree (web)",
  "scripts": {
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "native:start": "cd native && npx expo start",
    "native:tsc": "cd native && npx tsc --noEmit",
    "web:tsc": "cd web && npx tsc -b"
  }
}
